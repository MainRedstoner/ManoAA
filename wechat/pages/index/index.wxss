/* 异议图片浮层 */
.objection-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
  z-index: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.objection-img {
  display: block;
  opacity: 0;
  pointer-events: auto;
}
.objection-img.anim-show {
  animation: shakeFadeIn 0.3s ease forwards;
}
.objection-img.anim-hide {
  animation: fadeOut 0.15s ease forwards;
}
.objection-img.testimony-show {
  animation: fadeInCenter 0.2s ease forwards;
}
.objection-img.testimony-hide {
  animation: slideUpOut 0.5s ease forwards;
}
@keyframes shakeFadeIn {
  0% { opacity: 0; transform: translate(0, 0) scale(1); }
  20% { transform: translate(-48px, -48px) scale(1.05); }
  40% { transform: translate(48px, 48px) scale(1.05); }
  60% { transform: translate(-24px, -24px) scale(1.02); }
  80% { transform: translate(24px, 24px) scale(1.02); }
  100% { opacity: 1; transform: translate(0, 0) scale(1); }
}
@keyframes fadeOut {
  0% { opacity: 1; }
  100% { opacity: 0; }
}
@keyframes fadeInCenter {
  0% { opacity: 0; transform: scale(0.9); }
  100% { opacity: 1; transform: scale(1); }
}
@keyframes slideUpOut {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-120vh); }
}

